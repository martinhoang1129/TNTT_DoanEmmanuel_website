# ============================================
# Đoàn Emmanuel Website — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.

# --- Google Calendar ---
# Go to Google Calendar → Settings → [Your Calendar] → "Integrate calendar"
# Copy the "Embed code" iframe src URL (starts with https://calendar.google.com/...)
GOOGLE_CALENDAR_EMBED_URL=

# --- Google Sheets (Interest Form) ---
# Deploy a Google Apps Script as a web app that accepts POST requests.
# See README for setup instructions.
GOOGLE_SHEET_WEBHOOK_URL=

# --- Email Notifications (Interest Form) ---
# Sign up at https://resend.com (free: 100 emails/month)
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=
# The email address to receive form submission notifications
NOTIFY_EMAIL=

# --- Social Media ---
# Update the PLACEHOLDER URLs in components/Nav.tsx and components/Footer.tsx
# with your actual Instagram and Facebook page URLs.
